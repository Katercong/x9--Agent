# 本地硅基流动配置模板。真实 .env 已被 .gitignore 忽略。
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# PostgreSQL is started locally by Docker Compose. Keep real values only in
# .env (which is ignored by Git). POSTGRES_PASSWORD is the raw database
# password. Percent-encode URL-reserved characters in URL username/password
# components below (for example @ -> %40, : -> %3A, / -> %2F).
POSTGRES_DB=x9_replychat
POSTGRES_USER=x9_app
POSTGRES_PASSWORD=replace_with_a_unique_local_password
POSTGRES_PORT=5432
# Used by local uvicorn, Alembic and other host-side commands.
DATABASE_URL=postgresql+psycopg://x9_app:replace_with_a_unique_local_password@127.0.0.1:5432/x9_replychat
# Used only by Docker migrate, API, Worker and demo-seed containers.
DATABASE_URL_CONTAINER=postgresql+psycopg://x9_app:replace_with_a_unique_local_password@postgres:5432/x9_replychat

# Docker API only; defaults to 8000 when omitted.
API_PORT=8000
